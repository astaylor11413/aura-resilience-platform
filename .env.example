# --- MAPBOX CONFIGURATION ---
# Obtain from https://account.mapbox.com/
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here

# --- AURA PLATFORM API ---
# Points to your production backend: aura-resilience-platform-prod
# Production frontend: aura-resilience-platform-ui
VITE_AURA_API_BASE_URL=https://aura-resilience-platform-prod.onrender.com/api/v1

# --- APPLICATION SETTINGS ---
# Set to 'true' for local simulation, 'false' for production data sync
VITE_DEFAULT_AIR_GAPPED_MODE=false